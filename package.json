{
  "name": "french-departements",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node scripts/ensure-map-data.js && expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "build:all": "eas build --platform all --profile production",
    "submit:ios": "eas submit --platform ios --profile production --latest",
    "submit:android": "eas submit --platform android --profile production --latest",
    "build:map-data": "node scripts/build-map-data.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "check-secrets": "bash scripts/check-secrets.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.4",
    "expo": "~53.0.12",
    "expo-dev-client": "~5.2.4",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "fflate": "^0.8.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.4",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-svg": "15.11.2",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/react-native": "^13.3.3",
    "eas-cli": "^16.15.0",
    "jest": "~29.7.0",
    "jest-expo": "~53.0.0",
    "react-test-renderer": "^19.0.0"
  },
  "private": true
}
