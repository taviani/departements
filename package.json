{
  "name": "french-departements",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node scripts/start-go.js",
    "dev": "node scripts/start-go.js",
    "go": "node scripts/start-go.js",
    "dev:client": "node scripts/start-dev.js",
    "dev:sim": "node scripts/start-dev.js --simulator",
    "sim": "bash scripts/sim-test.sh",
    "dev:check": "node scripts/check-lan.js",
    "dev:iphone": "expo run:ios --device \"iPhone de Ed\"",
    "android": "expo run:android",
    "ios": "expo run:ios --device \"iPhone de Ed\"",
    "ios:sim": "expo run:ios",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "build:all": "eas build --platform all --profile production",
    "submit:ios": "eas submit --platform ios --profile production --latest",
    "submit:android": "eas submit --platform android --profile production --latest",
    "build:map-data": "node scripts/build-map-data.js",
    "check:expo-go": "node scripts/check-expo-go.js",
    "pretest": "node scripts/check-expo-go.js",
