# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# Environment and secrets (never commit real values)
.env
.env.*
!.env.example
AuthKey_*.p8
credentials.json
eas-credentials.json
google-play-service-account.json
*-service-account*.json

# Local-only env overrides
.env*.local
ios/.xcode.env.local

# Xcode user-specific data
**/xcuserdata/

# Native build artifacts
ios/build/

# Raw GeoJSON source (regenerate with npm run build:map-data)
data/departements.geojson
data/departements-map.json

# typescript
*.tsbuildinfo
